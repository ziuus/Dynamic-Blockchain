#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/zius/Projects/Dynamic-Blockchain/node_modules/.pnpm/uuid@14.0.0/node_modules/uuid/node_modules:/home/zius/Projects/Dynamic-Blockchain/node_modules/.pnpm/uuid@14.0.0/node_modules:/home/zius/Projects/Dynamic-Blockchain/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/zius/Projects/Dynamic-Blockchain/node_modules/.pnpm/uuid@14.0.0/node_modules/uuid/node_modules:/home/zius/Projects/Dynamic-Blockchain/node_modules/.pnpm/uuid@14.0.0/node_modules:/home/zius/Projects/Dynamic-Blockchain/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../dist-node/bin/uuid" "$@"
else
  exec node  "$basedir/../../dist-node/bin/uuid" "$@"
fi
